# Copy to .env for local dev. In Render, set these in the dashboard instead.

DATABASE_URL=sqlite:///./app.db
JWT_SECRET=please-generate-a-long-random-string

GEMINI_API_KEY=your-google-ai-studio-key
AI_MODEL=gemini-2.5-flash

# Razorpay Test Mode keys (Dashboard -> Settings -> API Keys -> Generate Test Key)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
RAZORPAY_WEBHOOK_SECRET=       # leave blank locally; set after deploy
PRO_PRICE_INR=499

FRONTEND_URL=http://localhost:5173
FREE_CONTACT_LIMIT=10
FREE_AI_DAILY_LIMIT=3
